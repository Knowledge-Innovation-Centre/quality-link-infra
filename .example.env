#==============================================================================
# POSTGRES
#==============================================================================
# Container and network
#POSTGRES_PORT=5432

# Database settings
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=quality_link_db

#==============================================================================
# DRAGONFLY (REDIS)
#==============================================================================
# Container and network
#DRAGONFLY_PORT=6379

# Image and basic config
DRAGONFLY_PASSWORD=your_redis_password

# Performance settings
#DRAGONFLY_CACHE_MODE=true
#DRAGONFLY_DBNAME=dump
#DRAGONFLY_DBNUM=6
#DRAGONFLY_HZ=100
#DRAGONFLY_KEYS_OUTPUT_LIMIT=8192
#DRAGONFLY_SNAPSHOT_CRON=* * * * *

#==============================================================================
# MINIO (S3-COMPATIBLE STORAGE)
#==============================================================================
# Container and network
#MINIO_API_PORT=9000
#MINIO_CONSOLE_PORT=9001

# Image and basic config

# Authentication
MINIO_ROOT_USER=minio_user
MINIO_ROOT_PASSWORD=minio_password

#BUCKET_NAME=quality-link-storage

#==============================================================================
# APACHE JENA FUSEKI CONFIGURATION
#==============================================================================

# Access & permissions
FUSEKI_ADMIN_PASSWORD=fuseki_password

# Container settings
#FUSEKI_PORT=3031

# Dataset settings
#FUSEKI_DATASET_NAME=qualitylink
#FUSEKI_TDB2_ENABLED=true
#FUSEKI_ENABLE_DATA_WRITE=true
#FUSEKI_ENABLE_UPDATE=true

# JVM settings
#FUSEKI_JVM_ARGS="-Xmx2g -XX:+UseContainerSupport"


#==============================================================================
# MAGEAI
#==============================================================================
# Container and network
#MAGEAI_PORT=6789

# Authentication
DEFAULT_OWNER_EMAIL=your_email@example.com
DEFAULT_OWNER_USERNAME=your_username
DEFAULT_OWNER_PASSWORD=your_password


#==============================================================================
# BACKEND
#==============================================================================

#BACKEND_PORT=8000

# Database name (should match POSTGRES_DB or a specific DB your backend uses)
DB_NAME=backend

#==============================================================================
# FRONTEND CONFIGURATION
#==============================================================================

# Container settings
FRONTEND_PORT=3333

# Environment variables for the app
VITE_API_URL=$SERVICE_URL_BACKEND
VITE_RECAPTCHA_SITE_KEY=API_KEY

