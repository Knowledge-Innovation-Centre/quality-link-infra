FROM node:20-alpine

WORKDIR /app

COPY package*.json ./

RUN npm install

RUN npm i -g serve

COPY . .

ARG VITE_RECAPTCHA_SITE_KEY
ARG VITE_API_URL
ARG VITE_RECAPTCHA_ENABLED=true
ENV VITE_RECAPTCHA_SITE_KEY=$VITE_RECAPTCHA_SITE_KEY
ENV VITE_API_URL=$VITE_API_URL
ENV VITE_RECAPTCHA_ENABLED=$VITE_RECAPTCHA_ENABLED

RUN npm run build

EXPOSE 3000

CMD ["serve", "-s", "dist"]
